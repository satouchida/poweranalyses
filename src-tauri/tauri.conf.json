{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Power Analyses",
  "version": "0.3.0",
  "identifier": "me.satouchida.poweranalyses",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "just serve",
    "beforeBuildCommand": "just build"
  },
  "app": {
    "windows": [
      {
        "title": "Open Power Analyses",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}